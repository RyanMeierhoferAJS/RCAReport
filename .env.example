# Telegram — get token from @BotFather, user ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings — text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Supabase — use the service role key (not anon)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Calendar iCal feeds
# Outlook: Calendar > Share > Publish > copy ICS link
# Google: Calendar Settings > Integrate calendar > Secret address in iCal format
CALENDAR_ICAL_URL_AJS=
CALENDAR_ICAL_URL_ASR=
CALENDAR_ICAL_URL_HOME=
