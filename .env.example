# Telegram — get token from @BotFather, user ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (embeddings — text-embedding-3-small)
OPENAI_API_KEY=sk-...

# Supabase — use the service role key (not anon)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Microsoft Graph — Azure portal > App registrations > PIA
# Covers AJS Outlook calendar + email
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_USER_EMAIL=ryan.meierhofer@ajsassetcare.co.uk

# Additional calendar iCal feeds (non-AJS accounts — blank = skipped)
# Outlook: Calendar > Share > Publish > ICS link
# Google: Calendar Settings > Integrate calendar > Secret iCal address
CALENDAR_ICAL_URL_ASR=
CALENDAR_ICAL_URL_HOME=
